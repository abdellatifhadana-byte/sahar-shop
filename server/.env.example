# ============================================================
# AI Commerce OS — Configuration
# Copy this file to .env and fill your values
# ============================================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# PRODUCTION_URL=https://yourdomain.com

# JWT — REQUIRED: generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE-THIS-TO-A-RANDOM-STRING-MIN-32-CHARS

# ── AI (Optional — app works without these) ─────────────────

# OpenAI (for smart AI replies in Arabic/Darija)
OPENAI_API_KEY=sk-...

# Google Gemini (free alternative to OpenAI)
GEMINI_API_KEY=AIzaSy...

# ── Meta / WhatsApp (Optional) ───────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=my-webhook-verify-token-123
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Auto-create admin on first start (Optional) ──────────────
ADMIN_EMAIL=admin@mystore.ma
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=المدير
